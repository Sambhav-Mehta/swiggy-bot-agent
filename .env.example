# ── Swiggy Bot — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model fallback chain (tried left-to-right on quota / overload)
SWIGGY_BOT_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash

# Swiggy MCP proxy URL — from your claude.ai MCP server integration settings.
# In Claude Code, check ~/.claude/.credentials.json for the proxy base URL,
# then find the server ID from your claude.ai connected apps page.
SWIGGY_FOOD_MCP_URL=https://mcp-proxy.anthropic.com/v1/mcp/your_server_id_here

# Swiggy session token — claude.ai OAuth token used to authenticate against
# the MCP proxy. Found at: ~/.claude/.credentials.json → claudeAiOauth.accessToken
SWIGGY_SESSION_TOKEN=sk-ant-oat01-your_token_here

# Your Swiggy delivery address ID for Viman Nagar (or wherever you want delivery).
# Run the get_addresses MCP tool once to find your addressId.
SWIGGY_ADDRESS_ID=your_address_id_here
