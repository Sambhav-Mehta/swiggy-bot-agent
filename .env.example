# ── Swiggy Bot — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Google Gemini ──────────────────────────────────────────────────────────────
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model fallback chain (tried left-to-right on quota / overload)
SWIGGY_BOT_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash

# ── Swiggy MCP ────────────────────────────────────────────────────────────────
# Anthropic MCP proxy URL — from your claude.ai connected apps page
SWIGGY_FOOD_MCP_URL=https://mcp-proxy.anthropic.com/v1/mcp/your_server_id_here

# claude.ai OAuth token — ~/.claude/.credentials.json → claudeAiOauth.accessToken
SWIGGY_SESSION_TOKEN=sk-ant-oat01-your_token_here

# Default Swiggy address ID (fallback when no user address is set)
SWIGGY_ADDRESS_ID=your_address_id_here

# ── Supabase (Database + Auth) ────────────────────────────────────────────────
# Create a free project at https://supabase.com and grab these from:
# Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your_anon_key...
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key...

# JWT secret — Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (used for OAuth callbacks in Phase 2)
APP_URL=https://swiggy-bot-agent.onrender.com
